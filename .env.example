# Скопіюйте цей файл у .env і підставте свої значення

# Токен бота від @BotFather (обов'язково)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Публічний HTTPS URL до сервера.
# Для локальної розробки:  python expose.py  → вставте посилання звідси.
# Для продакшену:           URL Railway/Render (https://...up.railway.app).
# Без нього кнопка WebApp у Telegram не працюватиме.
WEBAPP_URL=

# Порт локального сервера
PORT=8000

# Telegram ID адміністраторів через кому (хто додає музику для всіх
# та завантажує файли у хмару). Дізнатись ID: @userinfobot
ADMIN_IDS=

# ----- Supabase (опціонально, для збереження музики у хмарі) -----
# Якщо порожні — завантаження файлів вимкнене, але працюють
# демо-треки та прямі посилання.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=tracks
